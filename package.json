    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@posthog/cli",
    "@vercel/speed-insights",
    "better-sqlite3",
    "core-js",
    "esbuild",
    "sharp",
