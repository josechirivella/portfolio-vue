{
  "name": "portfolio-vue",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --dotenv .env.local",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "nuxt start",
    "lint:js": "oxlint",
    "lint:js:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint:style": "stylelint \"**/*.{vue,css,scss}\" --ignore-path .gitignore",
    "lint": "bun lint:js && bun lint:style",
    "test": "vitest run --project nuxt",
    "test:watch": "vitest --project nuxt",
    "test:coverage": "vitest run --project nuxt --coverage"
  },
  "dependencies": {
    "@posthog/nuxt": "^1.5.83",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^2.0.0",
    "better-sqlite3": "^12.6.2",
    "primevue": "^4.5.4",
    "tailwindcss-primeui": "^0.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@iconify-json/ci": "^1.2.2",
    "@iconify-json/fa-brands": "^1.2.2",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@nuxt/content": "^3.12.0",
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/stylelint-module": "^5.2.1",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@primevue/nuxt-module": "^4.5.4",
    "@types/bun": "^1.3.10",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "^1.6.11",
    "eslint-plugin-nuxt": "^4.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "nuxt": "^4.4.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,vue}": "oxlint",
    "*.{css,vue}": "stylelint"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@posthog/cli",
    "@vercel/speed-insights",
    "better-sqlite3",
    "core-js",
    "esbuild",
    "sharp",
    "unrs-resolver",
    "vue-demi"
  ]
